---
import { formatDate, slugFromId, type BlogPost } from "@/lib/blog";

interface Props {
  posts: BlogPost[];
  class?: string;
}

const { posts, class: className = "" } = Astro.props;
---

<div class:list={["post-list", className]}>
  {posts.map((post) => (
    <article class="post-item">
      <a href={`/blog/${slugFromId(post.id)}/`}>
        <span>{formatDate(post.data.date)}</span>
        <strong>{post.data.title}</strong>
        {post.data.description && <p>{post.data.description}</p>}
      </a>
    </article>
  ))}
</div>
