---
import "katex/dist/katex.min.css";
import { render } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import MilestoneTimeline from "@/components/MilestoneTimeline.astro";
import PostList from "@/components/PostList.astro";
import { formatDate, readingMinutes, routePart, slugFromId, type BlogPost } from "@/lib/blog";
import { site } from "@/site.config";

interface Props {
  post: BlogPost;
  newer?: BlogPost;
  older?: BlogPost;
  relatedPosts?: BlogPost[];
}

const { post, newer, older, relatedPosts = [] } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter(({ depth }) => depth >= 2 && depth <= 3);
const description = post.data.description ?? `${post.data.title} - ${formatDate(post.data.date)}`;
const minutes = readingMinutes(post.body ?? "");
const baseUrl = Astro.site ?? Astro.url.origin;
const articleUrl = post.data.canonicalUrl ?? new URL(`/blog/${slugFromId(post.id)}/`, baseUrl).href;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.date).toISOString(),
  author: {
    "@type": "Person",
    name: site.author,
    url: site.github
  },
  mainEntityOfPage: articleUrl,
  keywords: [...post.data.categories, ...post.data.tags].join(", ")
};
---

<BaseLayout
  title={post.data.title}
  description={description}
  type="article"
  canonicalUrl={articleUrl}
  jsonLd={jsonLd}
>
  <div
    class="reading-progress"
    role="progressbar"
    aria-label="Reading progress"
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="0"
  >
    <span></span>
  </div>

  <div class="article-layout">
    {tocHeadings.length > 0 && (
      <aside class="article-toc article-toc--desktop" aria-label="On this page">
        <p>On this page</p>
        <ul>
          {tocHeadings.map((heading) => (
            <li>
              <a class={`toc-link toc-link--depth-${heading.depth}`} href={`#${heading.slug}`}>
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <article class="article-shell">
      <header class="article-header">
        <p class="eyebrow">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          <span aria-hidden="true"> · </span>
          <span>{minutes} min read</span>
        </p>
        <h1>{post.data.title}</h1>
        {post.data.updatedDate && (
          <p class="article-updated">
            Updated <time datetime={post.data.updatedDate.toISOString()}>{formatDate(post.data.updatedDate)}</time>
          </p>
        )}
        <div class="term-row" aria-label="Categories and tags">
          {post.data.categories.map((category) => (
            <a href={`/categories/${routePart(category)}/`}>{category}</a>
          ))}
          {post.data.tags.map((tag) => (
            <a href={`/tags/${routePart(tag)}/`}>#{tag}</a>
          ))}
        </div>
      </header>

      {tocHeadings.length > 0 && (
        <details class="article-toc article-toc--mobile">
          <summary>On this page</summary>
          <nav aria-label="On this page">
            <ul>
              {tocHeadings.map((heading) => (
                <li>
                  <a class={`toc-link toc-link--depth-${heading.depth}`} href={`#${heading.slug}`}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </details>
      )}

      <div class="prose">
        <Content />
      </div>

      {post.data.milestones && post.data.milestones.length > 0 && (
        <section class="milestone-listing article-milestones" aria-labelledby="article-milestones">
          <h2 id="article-milestones">Milestones</h2>
          <MilestoneTimeline items={post.data.milestones} />
        </section>
      )}

      {(newer || older) && (
        <nav class="post-navigation" aria-label="Adjacent posts">
          {newer && (
            <a class="post-navigation__link post-navigation__link--newer" rel="next" href={`/blog/${slugFromId(newer.id)}/`}>
              <small>Newer</small>
              <span>{newer.data.title}</span>
            </a>
          )}
          {older && (
            <a class="post-navigation__link post-navigation__link--older" rel="prev" href={`/blog/${slugFromId(older.id)}/`}>
              <small>Older</small>
              <span>{older.data.title}</span>
            </a>
          )}
        </nav>
      )}

      {relatedPosts.length > 0 && (
        <section class="related-posts" aria-labelledby="related-posts">
          <h2 id="related-posts">Related notes</h2>
          <PostList posts={relatedPosts} />
        </section>
      )}

      <a class="back-to-top" href="#main">Back to top</a>
    </article>
  </div>

  <script>
    const progress = document.querySelector<HTMLElement>(".reading-progress");
    const progressFill = progress?.querySelector<HTMLElement>("span");
    const article = document.querySelector<HTMLElement>(".prose");
    const articleHeadings = Array.from(
      article?.querySelectorAll<HTMLElement>("h2[id], h3[id]") ?? []
    );
    const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>(".toc-link"));
    let updateRequested = false;

    const updateReadingState = () => {
      updateRequested = false;

      if (!article || !progress || !progressFill) return;

      const articleTop = article.getBoundingClientRect().top + window.scrollY;
      const articleBottom = articleTop + article.offsetHeight;
      const readingEnd = Math.max(articleTop, articleBottom - window.innerHeight);
      const readingDistance = Math.max(readingEnd - articleTop, 1);
      const percentage = Math.min(100, Math.max(0, ((window.scrollY - articleTop) / readingDistance) * 100));

      progressFill.style.transform = `scaleX(${percentage / 100})`;
      progress.setAttribute("aria-valuenow", String(Math.round(percentage)));

      if (articleHeadings.length === 0) return;

      const activationLine = window.scrollY + Math.min(window.innerHeight * 0.3, 160);
      let activeHeading = articleHeadings[0];

      for (const heading of articleHeadings) {
        const headingTop = heading.getBoundingClientRect().top + window.scrollY;
        if (headingTop > activationLine) break;
        activeHeading = heading;
      }

      for (const link of tocLinks) {
        const isActive = link.getAttribute("href") === `#${activeHeading.id}`;
        link.classList.toggle("is-active", isActive);
        if (isActive) {
          link.setAttribute("aria-current", "location");
        } else {
          link.removeAttribute("aria-current");
        }
      }
    };

    const requestReadingStateUpdate = () => {
      if (updateRequested) return;
      updateRequested = true;
      window.requestAnimationFrame(updateReadingState);
    };

    window.addEventListener("scroll", requestReadingStateUpdate, { passive: true });
    window.addEventListener("resize", requestReadingStateUpdate);
    requestReadingStateUpdate();
  </script>
</BaseLayout>
