---
import BlogPostLayout from "@/layouts/BlogPostLayout.astro";
import { getAllPosts, getPostNavigation, getRelatedPosts, slugFromId } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => {
    const navigation = getPostNavigation(posts, post);
    return {
      params: { slug: slugFromId(post.id) },
      props: {
        post,
        newer: navigation.newer,
        older: navigation.older,
        relatedPosts: getRelatedPosts(posts, post)
      }
    };
  });
}

const { post, newer, older, relatedPosts } = Astro.props;
---

<BlogPostLayout post={post} newer={newer} older={older} relatedPosts={relatedPosts} />
