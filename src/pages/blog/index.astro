---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate, getAllPosts, slugFromId } from "@/lib/blog";

const posts = await getAllPosts();
---

<BaseLayout title="Blog">
  <section class="shell page-title">
    <p class="eyebrow">All notes</p>
    <h1>Blog</h1>
  </section>

  <section class="shell listing" aria-labelledby="all-posts">
    <div class="section-head">
      <h2 id="all-posts">All Posts</h2>
      <p>{posts.length} notes</p>
    </div>
    <div class="post-list">
      {posts.map((post) => (
        <article class="post-item">
          <a href={`/blog/${slugFromId(post.id)}/`}>
            <span>{formatDate(post.data.date)}</span>
            <strong>{post.data.title}</strong>
            <p>{post.data.description ?? "Markdown technical note."}</p>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
