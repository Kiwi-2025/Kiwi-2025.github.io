---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostList from "@/components/PostList.astro";
import { getAllPosts, getCategories, routeLabel } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return getCategories(posts).map((category) => ({
    params: { category: category.name },
    props: { category: category.name, posts: posts.filter((post) => post.data.categories.includes(category.name)) }
  }));
}

const { category, posts } = Astro.props;
const label = category ?? routeLabel(Astro.params.category);
---

<BaseLayout
  title={`Category: ${label}`}
  description={`${label} 分类下的技术笔记与文章，共 ${posts.length} 篇。`}
>
  <section class="shell page-title">
    <p class="eyebrow">Category</p>
    <h1>{label}</h1>
  </section>
  <section class="shell" aria-label="Notes in category">
    <PostList posts={posts} />
  </section>
</BaseLayout>
