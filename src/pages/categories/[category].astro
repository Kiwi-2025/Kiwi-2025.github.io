---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate, getAllPosts, getCategories, routeLabel, slugFromId } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return getCategories(posts).map((category) => ({
    params: { category: category.name },
    props: { category: category.name, posts: posts.filter((post) => post.data.categories.includes(category.name)) }
  }));
}

const { category, posts } = Astro.props;
const label = category ?? routeLabel(Astro.params.category);
---

<BaseLayout title={`Category: ${label}`}>
  <section class="shell page-title">
    <p class="eyebrow">Category</p>
    <h1>{label}</h1>
  </section>
  <section class="shell post-list" aria-label="Notes in category">
    {posts.map((post) => (
      <article class="post-item">
        <a href={`/blog/${slugFromId(post.id)}/`}>
          <span>{formatDate(post.data.date)}</span>
          <strong>{post.data.title}</strong>
          <p>{post.data.description ?? "Markdown technical note."}</p>
        </a>
      </article>
    ))}
  </section>
</BaseLayout>
