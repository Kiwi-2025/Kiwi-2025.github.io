---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllPosts, getCategories, routePart } from "@/lib/blog";

const categories = getCategories(await getAllPosts());
---

<BaseLayout title="Categories">
  <section class="shell page-title">
    <p class="eyebrow">Categories</p>
    <h1>Categories</h1>
  </section>
  <section class="shell term-grid" aria-label="All categories">
    {categories.map((category) => (
      <a href={`/categories/${routePart(category.name)}/`}>
        <span>{category.name}</span>
        <small>{category.count} notes</small>
      </a>
    ))}
  </section>
</BaseLayout>
