---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MilestoneTimeline from "@/components/MilestoneTimeline.astro";
import PostList from "@/components/PostList.astro";
import { getAllPosts, slugFromId } from "@/lib/blog";
import { site } from "@/site.config";

const posts = await getAllPosts();
const recentPosts = posts.slice(0, 5);
const featuredPosts = posts
  .filter((post) => post.data.featured)
  .slice(0, 3);
const milestonePost = posts.find((post) => slugFromId(post.id).toLowerCase() === "milestone");
const milestoneItems = milestonePost?.data.milestones ?? [];
---

<BaseLayout>
  <section class="intro shell">
    <h1>{site.title}</h1>
    <p>{site.intro}</p>
    <nav class="social-links" aria-label="Site links">
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
      <a href="/categories/">Categories</a>
      <a href="/tags/">Tags</a>
    </nav>
  </section>

  <section class="shell listing" aria-labelledby="recent-posts">
    <div class="section-head">
      <h2 id="recent-posts">Recent Notes</h2>
      <p>{recentPosts.length} notes</p>
    </div>
    <PostList posts={recentPosts} />
  </section>

  {featuredPosts.length > 0 && (
    <section class="shell listing" aria-labelledby="featured-posts">
      <div class="section-head">
        <h2 id="featured-posts">Featured</h2>
      </div>
      <PostList posts={featuredPosts} class="featured-list" />
    </section>
  )}

  {milestonePost && milestoneItems.length > 0 && (
    <section class="shell listing milestone-listing" aria-labelledby="milestone-updates">
      <div class="section-head">
        <h2 id="milestone-updates">Milestone</h2>
        <a class="text-link" href="/blog/milestone/">View note</a>
      </div>
      <MilestoneTimeline items={milestoneItems} />
    </section>
  )}
</BaseLayout>
