---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostList from "@/components/PostList.astro";
import { getAllPosts, getTags, routeLabel } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return getTags(posts).map((tag) => ({
    params: { tag: tag.name },
    props: { tag: tag.name, posts: posts.filter((post) => post.data.tags.includes(tag.name)) }
  }));
}

const { tag, posts } = Astro.props;
const label = tag ?? routeLabel(Astro.params.tag);
---

<BaseLayout
  title={`Tag: ${label}`}
  description={`带有 ${label} 标签的技术笔记与文章，共 ${posts.length} 篇。`}
>
  <section class="shell page-title">
    <p class="eyebrow">Tag</p>
    <h1>#{label}</h1>
  </section>
  <section class="shell" aria-label="Notes with tag">
    <PostList posts={posts} />
  </section>
</BaseLayout>
